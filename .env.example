# ============================================================
# GOOGLE CUSTOM SEARCH API - KONFIGURASI
# ============================================================
# 
# CARA DAPATKAN API KEY:
# 1. Buka https://console.cloud.google.com/
# 2. Buat project baru (atau pilih existing)
# 3. Masuk ke "APIs & Services" → "Library"
# 4. Cari "Custom Search API" → klik → "Enable"
# 5. Masuk ke "Credentials" → "Create Credentials" → "API Key"
# 6. Salin API Key-nya
#
# CARA DAPATKAN CX (Search Engine ID):
# 1. Buka https://programmablesearchengine.google.com/
# 2. Klik "Add" untuk buat search engine baru
# 3. Di "Sites to search", pilih "Search the entire web"
# 4. Isi nama, lalu klik "Create"
# 5. Di halaman berikutnya, cari "Search engine ID" (cx)
# 6. Salin CX-nya
#
# GRATIS: 100 query/hari, 1 query = 10 hasil gambar
# Untuk 2781 produk, butuh ~278 query = ~3 hari
# Atau upgrade di Google Cloud untuk kuota lebih

GOOGLE_API_KEY=your_api_key_here
GOOGLE_CX=your_search_engine_id_here
